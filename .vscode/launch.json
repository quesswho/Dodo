{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Sandbox",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/Debug/Sandbox",
      "cwd": "${workspaceFolder}/build/bin/Debug",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for STL",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Debug DodoEditor",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/Debug/DodoEditor",
      "cwd": "${workspaceFolder}/build/bin/Debug",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for STL",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}